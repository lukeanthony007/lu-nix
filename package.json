{
  "name": "lu-nix",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*"],
  "scripts": {
    "build": "pnpm --filter @lu-nix/web build",
    "check": "pnpm --filter @lu-nix/web check",
    "dev": "pnpm --filter @lu-nix/web dev",
    "fmt": "pnpm exec biome format --write .",
    "lint": "pnpm exec biome check ."
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@biomejs/biome": "^1.9.4",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  }
}
